# 星火 APP 后端运行配置
# 复制此文件为 .env 并填写真实值

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=xinghuo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 微信小程序
WX_APPID=wx5890cbc3c95f6599
WX_SECRET=your-wechat-secret-here

# 微信支付
WX_MCHID=your-merchant-id
WX_API_KEY=your-pay-api-key
WX_NOTIFY_URL=https://xinghuo.tongshengwangluo.com/api/v1/pay/notify
WX_CERT_PATH=/path/to/apiclient_cert.pem
WX_KEY_PATH=/path/to/apiclient_key.pem

# JWT
JWT_EXPIRATION_HOURS=72
